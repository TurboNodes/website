// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @db.Uuid
  email     String   @unique
  username  String?  @unique
  preferences   Json? // Example: { "theme": "dark", "notifications": true }

  totalEarnings Decimal  @default(0) @db.Decimal(18, 4)
  todayEarnings Decimal  @default(0) @db.Decimal(18, 4)

  referralCode    String   @unique
  referralBalance Decimal  @default(0) @db.Decimal(18, 4)
  referredById    String?  @db.Uuid
  referredBy      User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referralsMade   User[]   @relation("UserReferrals")

  createdAt DateTime @default(now())
  // updatedAt DateTime @updatedAt

  nodes Node[]
  referralsAsReferrer Referral[] @relation("Referrer")
  referralsAsReferred Referral[] @relation("Referred")
  referralEarnings    ReferralEarning[] @relation("ReferrerEarnings")

  @@map("users")
}

model Node {
  id          String   @id @db.Uuid
  isActive    Boolean  @default(true)
  nodeIp      String?  @unique @map("nodeIp")
  
  // Structure: { "2024-01-15": 25.50, "2024-01-16": 30.25, ... }
  dailyEarnings Json     @default("{}") @db.JsonB
  bandwidthUsed Float? // in GB
  uptimeMinutes Int?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([isActive])

  @@map("nodes")
}

model Referral {
  id                          String   @id @default(uuid()) @db.Uuid
  referrerId                  String   @db.Uuid
  referredId                  String   @unique @db.Uuid
  earningsCommissionedThrough Decimal  @default(0) @db.Decimal(18, 4)
  milestoneBonusPaid          Boolean  @default(false)
  createdAt                   DateTime @default(now())

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@map("referrals")
}

model ReferralEarning {
  id                  String   @id @default(uuid()) @db.Uuid
  referrerId          String   @db.Uuid
  referredId          String   @db.Uuid
  type                String   // milestone_bonus | commission
  amount              Decimal  @db.Decimal(18, 4)
  sourceEarningsDelta Decimal? @db.Decimal(18, 4)
  createdAt           DateTime @default(now())

  referrer User @relation("ReferrerEarnings", fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([createdAt])
  @@map("referral_earnings")
}
